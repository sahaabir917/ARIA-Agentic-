# ─── ARIA Backend Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in real values before running.
# Never commit .env to version control — only commit this example file.

# ── LLM API Keys ──────────────────────────────────────────────────────────────
# console.anthropic.com → API Keys → Create Key
# Used by: Orchestrator (Opus 4.6), Development Agent (Sonnet 4.6),
#          Market Research Agent (Sonnet 4.6), Synthesizer (Opus 4.6)
ANTHROPIC_API_KEY=sk-ant-...

# platform.openai.com → API keys → Create new secret key
# Used by: Marketing Agent, Sales Agent, Finance Agent (all GPT-4o)
#          + embedding pipeline (text-embedding-3-small)
OPENAI_API_KEY=sk-...

# aistudio.google.com → Get API key
# Used by: Design Agent, HR Agent (both Gemini 1.5 Pro)
GOOGLE_API_KEY=AIza...

# app.tavily.com → API → Copy key
# Used by: Market Research Agent (live web search)
TAVILY_API_KEY=tvly-...

# console.groq.com → API Keys → Create Key
# TESTING MODE: when set, ALL agents use Groq (llama-3.3-70b-versatile)
# instead of Anthropic/OpenAI/Google — only one key needed for full pipeline testing
# Note: RAG embeddings still require OPENAI_API_KEY (Groq has no embeddings API)
GROQ_API_KEY=gsk_...

# ── Supabase ───────────────────────────────────────────────────────────────────
# Supabase → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# ── Database ───────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
# Auto-set by docker-compose for local dev
DATABASE_URL=postgresql+asyncpg://aria:aria@localhost:5432/aria

# ── Redis ──────────────────────────────────────────────────────────────────────
# Format: redis://<host>:<port>/<db>
# Auto-set by docker-compose for local dev
REDIS_URL=redis://localhost:6379/0
